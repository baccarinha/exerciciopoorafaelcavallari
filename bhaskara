<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Bháskara</title>

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
            padding: 20px;
            background: linear-gradient(135deg, #4e73df, #9b59b6, #ff66cc);
            color: white;
            text-align: center;
        }

        .container {
            background: white;
            color: black;
            padding: 30px;
            border-radius: 15px;
            max-width: 600px;
            margin: auto;
        }

        pre {
            text-align: left;
            background: #f4f4f4;
            padding: 15px;
            border-radius: 10px;
            overflow-x: auto;
        }

        input {
            padding: 10px;
            margin: 5px;
            width: 100px;
            text-align: center;
        }

        button {
            padding: 10px 20px;
            margin: 10px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        .executar {
            background-color: #4e73df;
            color: white;
        }

        .voltar {
            background-color: #e74a3b;
            color: white;
        }

        #resultado {
            margin-top: 15px;
            font-weight: bold;
        }

        footer {
            margin-top: 30px;
            color: white;
        }
    </style>
</head>
<body>

    <h1>Bháskara</h1>

    <div class="container">

        <h3>Código em Python:</h3>

        <pre>
import math

a = float(input("Digite o valor de a: "))
b = float(input("Digite o valor de b: "))
c = float(input("Digite o valor de c: "))

if a == 0:
    print("Não é uma equação do segundo grau.")
else:
    delta = b**2 - 4*a*c
    print(f"Delta = {delta}")

    if delta < 0:
        print("Não há raízes reais.")
    elif delta == 0:
        x = -b / (2*a)
        print(f"Raiz: x = {x}")
    else:
        x1 = (-b + math.sqrt(delta)) / (2*a)
        x2 = (-b - math.sqrt(delta)) / (2*a)
        print(f"x1 = {x1}")
        print(f"x2 = {x2}")
        </pre>

        <h3>Executar:</h3>

        <input type="number" id="a" placeholder="a">
        <input type="number" id="b" placeholder="b">
        <input type="number" id="c" placeholder="c">
        <br>

        <button class="executar" onclick="calcular()">Executar</button>
        <button class="voltar" onclick="window.location.href='index.html'">Voltar</button>

        <div id="resultado"></div>

    </div>

    <footer>
        Nome: Jéssica Thais Baccaro
    </footer>

    <script>
        function calcular() {
            let a = parseFloat(document.getElementById("a").value);
            let b = parseFloat(document.getElementById("b").value);
            let c = parseFloat(document.getElementById("c").value);
            let resultado = document.getElementById("resultado");

            if (a === 0) {
                resultado.innerHTML = "Não é uma equação do segundo grau.";
                return;
            }

            let delta = b*b - 4*a*c;

            if (delta < 0) {
                resultado.innerHTML = "Delta = " + delta + "<br>Não há raízes reais.";
            } 
            else if (delta === 0) {
                let x = -b / (2*a);
                resultado.innerHTML = "Delta = " + delta + "<br>Uma raiz real: x = " + x;
            } 
            else {
                let x1 = (-b + Math.sqrt(delta)) / (2*a);
                let x2 = (-b - Math.sqrt(delta)) / (2*a);
                resultado.innerHTML = "Delta = " + delta + 
                    "<br>Duas raízes reais:" +
                    "<br>x1 = " + x1 +
                    "<br>x2 = " + x2;
            }
        }
    </script>

</body>
</html>
